"use client";


import { useState } from "react";
import { storyblokEditable, StoryblokComponent } from "@storyblok/react";

const Grid = ({ blok }: any) => {
  const [currentPage, setCurrentPage] = useState(0);
  
  // Check if this grid contains testimonials (with capital T!)
  const hasTestimonials = blok.columns?.some((col: any) => 
    col.component === "testimonial" || col.component === "Testimonial"
  );
  
  // Testimonial carousel logic
  const itemsPerPage = 3;
  const totalPages = hasTestimonials 
    ? Math.ceil((blok.columns?.length || 0) / itemsPerPage)
    : 0;
  
  const startIndex = currentPage * itemsPerPage;
  const endIndex = startIndex + itemsPerPage;
  const visibleItems = hasTestimonials 
    ? blok.columns?.slice(startIndex, endIndex) 
    : blok.columns;

  const nextPage = () => {
    setCurrentPage((prev) => (prev === totalPages - 1 ? 0 : prev + 1));
  };

  const prevPage = () => {
    setCurrentPage((prev) => (prev === 0 ? totalPages - 1 : prev - 1));
  };

  return (
    <div 
      {...storyblokEditable(blok)} 
      id={blok.section_id}
      className="container mx-auto px-4 py-12 scroll-mt-24"
    >
      {/* Testimonial Carousel */}
      {hasTestimonials ? (
        <div className="relative">
          {/* Grid of visible testimonials */}
          <div className="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 mb-8">
            {visibleItems?.map((nestedBlok: any) => (
              <div key={nestedBlok._uid}>
                <StoryblokComponent blok={nestedBlok} />
              </div>
            ))}
          </div>

          {/* Navigation Arrows - only show if more than 3 testimonials */}
          {totalPages > 1 && (
            <div className="flex items-center justify-center gap-4 mt-8">
              <button
                onClick={prevPage}
                className="bg-[#333333] text-white w-12 h-12 rounded-full flex items-center justify-center font-bold text-2xl hover:bg-[#CEDC00] hover:text-black transition-colors shadow-lg"
                aria-label="Previous reviews"
              >
                ←
              </button>
              
              {/* Page dots */}
              <div className="flex gap-2">
                {Array.from({ length: totalPages }).map((_, index) => (
                  <button
                    key={index}
                    onClick={() => setCurrentPage(index)}
                    className={`w-3 h-3 rounded-full transition-all ${
                      index === currentPage 
                        ? "bg-[#CEDC00] w-8" 
                        : "bg-gray-300 hover:bg-gray-400"
                    }`}
                    aria-label={`Go to page ${index + 1}`}
                  />
                ))}
              </div>

              <button
                onClick={nextPage}
                className="bg-[#333333] text-white w-12 h-12 rounded-full flex items-center justify-center font-bold text-2xl hover:bg-[#CEDC00] hover:text-black transition-colors shadow-lg"
                aria-label="Next reviews"
              >
                →
              </button>
            </div>
          )}
        </div>
      ) : (
        // Original layout for service cards
        <div className="flex flex-wrap justify-center gap-8">
          {blok.columns?.map((nestedBlok: any) => (
            <div key={nestedBlok._uid} className="w-full md:w-[30%]">
              <StoryblokComponent blok={nestedBlok} />
            </div>
          ))}
        </div>
      )}
    </div>
  );
};

export default Grid;
